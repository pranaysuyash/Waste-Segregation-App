# Golden test generated failure artifacts (auto-generated by tests)
# Keep official golden masters under `test/golden/golden/` checked in; ignore generated diffs and test images.
/test/golden/failures/
/test/golden/**/failures/
/test/golden/**/*_maskedDiff.png
/test/golden/**/*_isolatedDiff.png
/test/golden/**/*_masterImage.png
/test/golden/**/*_testImage.png
/test/golden/**/*_mask*.png
/test/golden/**/*_diff.png

# Widget golden test failures (auto-generated)
/test/widgets/failures/
/test/**/failures/

# Boringssl debug artifacts (local debugging files; do not commit)
/ios/boringssl*
/fix_boringssl_issue.sh
/ios/BoringSSL-Fix-Podfile.rb

# Environment templates (keep only the main template)
.env.template.*
.env.local
.env.development
.env.production
.env.staging

