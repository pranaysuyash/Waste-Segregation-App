{
  "name": "waste-segregation-rules-test",
  "version": "1.0.0",
  "private": true,
  "description": "Firestore rules unit tests for Waste Segregation App",
  "scripts": {
    "test": "mocha --exit --timeout 30000 rules-test.spec.js classification-feedback-rules-test.spec.js family-rules-test.spec.js",
    "test:emulator": "firebase emulators:exec --only firestore \"npm test\"",
    "test:classification-feedback": "mocha --exit --timeout 30000 classification-feedback-rules-test.spec.js",
    "test:family": "mocha --exit --timeout 30000 family-rules-test.spec.js"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^4.0.0",
    "mocha": "^10.0.0"
  },
  "dependencies": {
    "firebase": "^11.10.0"
  }
}
