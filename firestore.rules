rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ============================================================
    // SECTION 1: User-scoped collections
    // ============================================================

    // User profiles - users can only read/write their own data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // User's personal classifications (subcollection)
      match /classifications/{classificationId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      // Validate gamification profile updates (anti-cheat)
      allow update: if request.auth != null 
        && request.auth.uid == userId
        && validateGamificationUpdate(resource.data, request.resource.data);
    }
    
    // ============================================================
    // SECTION 2: AI & Token collections
    // ============================================================

    // AI Jobs - users can only access their own jobs
    match /ai_jobs/{jobId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }
    
    // Token Wallets - users can only access their own wallet data
    match /token_wallets/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Token Transactions - users can only access their own transactions
    match /token_transactions/{transactionId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }
    
    // ============================================================
    // SECTION 3: Leaderboard collections
    // ============================================================

    // All-time leaderboard - read all authenticated, write own entry
    // Schema: userId, displayName, photoUrl, points, lastUpdated, rank, weeklyPoints
    // Source: LeaderboardEntry model + cloud_storage_service.dart writes
    match /leaderboard_allTime/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null 
        && request.auth.uid == userId
        && validateLeaderboardEntry(request.resource.data)
        && request.resource.data.userId == request.auth.uid;
    }
    
    // Weekly leaderboard - read all authenticated, write own entry
    match /leaderboard_weekly/{weekId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null 
        && request.resource.data.userId == request.auth.uid
        && validateWeeklyLeaderboardEntry(request.resource.data)
        && isValidWeekId(weekId);
    }
    
    // ============================================================
    // SECTION 4: Community collections
    // ============================================================

    // Community feed - aligned with CommunityFeedItem model
    // Model fields: id, userId, userName, userAvatar, activityType, title,
    //   description, timestamp, metadata, likes, likedBy, isAnonymous, points
    // Privacy: userName/userAvatar are PII; isAnonymous controls display
    match /community_feed/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null 
        && request.resource.data.userId == request.auth.uid
        && validateCommunityFeedCreate(request.resource.data);
      allow update: if request.auth != null 
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid
        && validateCommunityFeedUpdate(resource.data, request.resource.data);
      allow delete: if request.auth != null 
        && resource.data.userId == request.auth.uid;
    }
    
    // Community stats (singleton document) - read-only for users
    match /community_stats/{statsId} {
      allow read: if request.auth != null;
      allow write: if false; // Managed by Cloud Functions / admin only
    }
    
    // Community challenges - read-only for users
    match /community_challenges/{challengeId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    
    // ============================================================
    // SECTION 5: Family collections
    // ============================================================

    // Families - aligned with Family.toJson() model fields.
    // memberUids: List<String> is a flat index of member user IDs maintained
    // alongside members: List<Map>. belongsToFamily() now checks uid in memberUids.
    // Legacy docs without memberUids fall back to createdBy check.
    match /families/{familyId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.createdBy == request.auth.uid
        && validateFamilyCreate(request.resource.data);
      allow update: if request.auth != null
        && (resource.data.createdBy == request.auth.uid
            || belongsToFamily(resource.data, request.auth.uid))
        && validateFamilyUpdate(resource.data, request.resource.data);
      allow delete: if request.auth != null
        && resource.data.createdBy == request.auth.uid;
    }
    
    // Family invitations - aligned with FamilyInvitation.toJson() model fields.
    // BUG FIX: original rule used inviterId (wrong field name); model uses inviterUserId.
    match /invitations/{invitationId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.inviterUserId == request.auth.uid
        && validateInvitationCreate(request.resource.data);
      allow update: if request.auth != null
        && validateInvitationUpdate(resource.data, request.resource.data);
      allow delete: if request.auth != null
        && (resource.data.inviterUserId == request.auth.uid
            || resource.data.invitedEmail == request.auth.token.email);
    }
    
    // Shared classifications within families - aligned with SharedWasteClassification.toJson()
    // BUG FIX: original rule only allowed sharedBy to update, blocking reactions/comments
    // from other family members. Now any authenticated user can update reactions/comments.
    match /shared_classifications/{classificationId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.sharedBy == request.auth.uid
        && validateSharedClassificationCreate(request.resource.data);
      allow update: if request.auth != null
        && validateSharedClassificationUpdate(resource.data, request.resource.data, request.auth.uid);
      allow delete: if request.auth != null
        && resource.data.sharedBy == request.auth.uid;
    }
    
    // Family stats - only family members can write.
    // Uses cross-doc get() to look up the family document and verify
    // that request.auth.uid is in family.memberUids or is createdBy.
    // family_stats/{familyId} doc ID matches families/{familyId} doc ID.
    match /family_stats/{familyId} {
      allow read: if request.auth != null
        && isFamilyMemberById(familyId, request.auth.uid);
      allow create: if request.auth != null
        && isFamilyMemberById(familyId, request.auth.uid);
      allow update: if request.auth != null
        && isFamilyMemberById(familyId, request.auth.uid);
      allow delete: if request.auth != null
        && isFamilyMemberById(familyId, request.auth.uid);
    }

    // ============================================================
    // SECTION 6: Classification feedback
    // ============================================================

    match /classification_feedback/{feedbackId} {
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && validateClassificationFeedbackCreate(request.resource.data);

      allow read: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow update: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && validateClassificationFeedbackUpdate(request.resource.data);
      allow delete: if false;
    }

    // ============================================================
    // SECTION 7: Reference data collections
    // ============================================================

    // Disposal instructions cache - read-only for users
    match /disposal_instructions/{materialId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    
    // Disposal locations - read-only for users
    match /disposal_locations/{locationId} {
      allow read: if request.auth != null;
      allow write: if false; // Managed by admin / Cloud Functions
    }
    
    // ============================================================
    // SECTION 8: User contributions
    // ============================================================

    match /user_contributions/{contributionId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null 
        && (resource.data.userId == request.auth.uid 
            || isPublicContribution(resource.data));
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
    
    // ============================================================
    // SECTION 9: Analytics
    // ============================================================

    // Analytics events - users can create their own, no read access
    match /analytics_events/{eventId} {
      allow create: if request.auth != null;
      allow read, update, delete: if false; // Admin/Cloud Functions only
    }
    
    // ============================================================
    // SECTION 10: Admin collections
    // ============================================================

    match /admin/{document=**} {
      allow read, write: if false;
    }
    
    match /admin_classifications/{document=**} {
      allow read, write: if false;
    }
    
    match /admin_user_recovery/{document=**} {
      allow read, write: if false;
    }
    
    // ============================================================
    // Gamification data (if stored as separate collection)
    // ============================================================
    
    match /gamification/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // ============================================================
    // VALIDATION FUNCTIONS
    // ============================================================

    // --- Leaderboard validation ---
    // Aligned with LeaderboardEntry model and cloud_storage_service.dart writes
    // FIX: Added 'photoUrl' to hasOnly whitelist (was missing, causing writes to fail)
    function validateLeaderboardEntry(data) {
      return data.keys().hasAll(['userId', 'points', 'displayName', 'lastUpdated'])
        && data.keys().hasOnly(['userId', 'points', 'displayName', 'lastUpdated', 'rank', 'weeklyPoints', 'photoUrl'])
        && data.userId is string
        && data.userId.size() > 0
        && data.points is number
        && data.points >= 0
        && data.points <= 1000000
        && data.displayName is string
        && data.displayName.size() > 0
        && data.displayName.size() <= 50
        && data.lastUpdated is timestamp;
    }
    
    function validateWeeklyLeaderboardEntry(data) {
      return data.keys().hasAll(['userId', 'weeklyPoints', 'weekId', 'lastUpdated'])
        && data.keys().hasOnly(['userId', 'weeklyPoints', 'weekId', 'lastUpdated', 'rank'])
        && data.userId is string
        && data.userId.size() > 0
        && data.weeklyPoints is number
        && data.weeklyPoints >= 0
        && data.weeklyPoints <= 10000
        && data.weekId is string
        && data.weekId.matches('^\\d{4}-W\\d{2}$')
        && data.lastUpdated is timestamp;
    }
    
    function isValidWeekId(weekId) {
      return weekId.matches('^\\d{4}-W\\d{2}$');
    }
    
    // --- Community feed validation ---
    // Aligned with CommunityFeedItem.toJson() model fields
    // Model: id, userId, userName, userAvatar, activityType, title, description,
    //        timestamp, metadata, likes, likedBy, isAnonymous, points
    // FIX: Previous rules required 'content' and 'type' (wrong field names),
    //      and only allowed 8 fields (model has 13). This blocked all writes.
    function validateCommunityFeedCreate(data) {
      return data.keys().hasAll(['id', 'userId', 'activityType', 'title', 'description', 'timestamp'])
        && data.userId is string
        && data.userId.size() > 0
        && data.userId == request.auth.uid
        && data.activityType is string
        && data.activityType in ['classification', 'achievement', 'streak', 'challenge', 'milestone', 'educational']
        && data.title is string
        && data.title.size() > 0
        && data.title.size() <= 500
        && data.description is string
        && data.description.size() <= 2000
        && data.timestamp is timestamp
        && (!data.keys().hasAny(['likes']) || (data.likes is number && data.likes >= 0))
        && (!data.keys().hasAny(['points']) || (data.points is number && data.points >= 0));
    }
    
    function validateCommunityFeedUpdate(oldData, newData) {
      return newData.userId == oldData.userId
        && newData.activityType == oldData.activityType
        && newData.timestamp == oldData.timestamp
        && newData.title is string
        && newData.title.size() > 0
        && newData.title.size() <= 500
        && (!newData.keys().hasAny(['likes']) || (newData.likes is number && newData.likes >= 0))
        && (!newData.keys().hasAny(['points']) || (newData.points is number && newData.points >= 0));
    }
    
    // --- Gamification validation ---
    function validateGamificationUpdate(oldData, newData) {
      let oldGamification = oldData.gamificationProfile;
      let newGamification = newData.gamificationProfile;
      
      return oldGamification != null 
        && newGamification != null
        && validatePointsIncrease(oldGamification, newGamification)
        && validateAchievementProgress(oldGamification, newGamification)
        && validateStreakLogic(oldGamification, newGamification);
    }
    
    function validatePointsIncrease(oldGamification, newGamification) {
      return newGamification.points.total >= oldGamification.points.total
        && newGamification.points.total <= oldGamification.points.total + 1000;
    }
    
    function validateAchievementProgress(oldGamification, newGamification) {
      return newGamification.achievements.size() >= oldGamification.achievements.size()
        && newGamification.achievements.size() <= oldGamification.achievements.size() + 5;
    }
    
    function validateStreakLogic(oldGamification, newGamification) {
      return newGamification.currentStreak == 0 
        || newGamification.currentStreak <= oldGamification.currentStreak + 1;
    }
    
    // --- Family helpers ---
    // Checks if a user is a member of a family using the memberUids index.
    // memberUids is a flat List<String> maintained by the app alongside members: List<Map>.
    // Falls back to createdBy check for legacy docs or as admin guarantee.
    function belongsToFamily(familyData, uid) {
      return uid in familyData.memberUids
        || familyData.createdBy == uid;
    }
    
    // Checks membership via cross-doc get() on the families collection.
    // family_stats/{familyId} doc ID matches families/{familyId}.
    function isFamilyMemberById(familyId, uid) {
      let family = get(/databases/$(database)/documents/families/$(familyId));
      return family != null
        && belongsToFamily(family.data, uid);
    }
    
    // --- Family validation ---
    // Aligned with Family.toJson() model fields.
    // Required: id, name, createdBy, createdAt, members, settings
    // Optional: description, updatedAt, imageUrl, isPublic
    function validateFamilyCreate(data) {
      return data.keys().hasAll(['id', 'name', 'createdBy', 'createdAt', 'members', 'memberUids', 'settings'])
        && data.keys().hasOnly(['id', 'name', 'description', 'createdBy', 'createdAt',
            'updatedAt', 'members', 'memberUids', 'settings', 'imageUrl', 'isPublic'])
        && data.createdBy is string
        && data.createdBy.size() > 0
        && data.name is string
        && data.name.size() > 0
        && data.name.size() <= 100
        && data.createdBy in data.memberUids;
    }
    
    function validateFamilyUpdate(oldData, newData) {
      return newData.createdBy == oldData.createdBy
        && newData.createdAt == oldData.createdAt
        && newData.id == oldData.id;
    }
    
    // --- Invitation validation ---
    // Aligned with FamilyInvitation.toJson() model fields.
    // Required: id, familyId, familyName, inviterUserId, invitedEmail,
    //           status, roleToAssign, method, createdAt, expiresAt
    // Optional: inviterName, invitedUserId, respondedAt
    function validateInvitationCreate(data) {
      return data.keys().hasAll(['id', 'familyId', 'familyName', 'inviterUserId',
            'invitedEmail', 'status', 'roleToAssign', 'method', 'createdAt', 'expiresAt'])
        && data.keys().hasOnly(['id', 'familyId', 'familyName', 'inviterUserId',
            'inviterName', 'invitedEmail', 'invitedUserId', 'status', 'roleToAssign',
            'method', 'createdAt', 'expiresAt', 'respondedAt'])
        && data.inviterUserId is string
        && data.inviterUserId.size() > 0
        && data.familyId is string
        && data.familyId.size() > 0
        && data.invitedEmail is string
        && data.invitedEmail.size() > 0
        && data.status is string
        && data.status in ['pending', 'accepted', 'declined', 'expired', 'revoked', 'cancelled']
        && data.roleToAssign is string
        && data.roleToAssign in ['admin', 'moderator', 'member'];
    }
    
    function validateInvitationUpdate(oldData, newData) {
      // Identity fields must not change
      return newData.familyId == oldData.familyId
        && newData.inviterUserId == oldData.inviterUserId
        && newData.invitedEmail == oldData.invitedEmail
        && newData.id == oldData.id
        && newData.method == oldData.method
        // Only the inviter or the invited user (by email) can update
        && (newData.inviterUserId == request.auth.uid
            || newData.invitedEmail == request.auth.token.email);
    }
    
    // --- Shared classification validation ---
    // Aligned with SharedWasteClassification.toJson() model fields.
    // Required: id, classification, sharedBy, sharedByDisplayName, sharedAt, familyId
    // Optional: sharedByPhotoUrl, reactions, comments, location, isVisible, familyTags
    function validateSharedClassificationCreate(data) {
      return data.keys().hasAll(['id', 'classification', 'sharedBy', 'sharedByDisplayName',
            'sharedAt', 'familyId'])
        && data.keys().hasOnly(['id', 'classification', 'sharedBy', 'sharedByDisplayName',
            'sharedByPhotoUrl', 'sharedAt', 'familyId', 'reactions', 'comments',
            'location', 'isVisible', 'familyTags'])
        && data.sharedBy is string
        && data.sharedBy.size() > 0
        && data.familyId is string
        && data.familyId.size() > 0
        && data.sharedByDisplayName is string
        && data.sharedByDisplayName.size() > 0;
    }
    
    function validateSharedClassificationUpdate(oldData, newData, authUid) {
      // Identity fields must not change
      return newData.sharedBy == oldData.sharedBy
        && newData.familyId == oldData.familyId
        && newData.id == oldData.id
        && newData.classification == oldData.classification
        // Only reactions and comments can be appended by any authenticated user
        // Other fields require the original sharer
        && newData.keys().hasOnly(['reactions', 'comments', 'sharedBy', 'sharedByDisplayName',
            'sharedByPhotoUrl', 'sharedAt', 'familyId', 'id', 'classification',
            'location', 'isVisible', 'familyTags']);
    }
    
    function isPublicContribution(data) {
      return data.status == 'approved' || data.visibility == 'public';
    }

    // --- Classification feedback validation ---
    // Aligned with ClassificationFeedback.toJson() model fields.
    // Required: userId, originalClassificationId, originalAIItemName,
    //           originalAICategory, userSuggestedCategory, feedbackTimestamp,
    //           reviewStatus, appVersion
    // Optional: originalAIMaterial, originalAIConfidence, userSuggestedItemName,
    //           userSuggestedMaterial, userNotes, adminReviewerId,
    //           adminReviewTimestamp, adminNotes, deviceInfo
    function validateClassificationFeedbackCreate(data) {
      return data.keys().hasAll([
        'userId', 'originalClassificationId', 'originalAIItemName',
        'originalAICategory', 'userSuggestedCategory', 'feedbackTimestamp',
        'reviewStatus', 'appVersion'
      ])
      && data.keys().hasOnly([
        'userId', 'originalClassificationId', 'originalAIItemName',
        'originalAICategory', 'originalAIMaterial', 'originalAIConfidence',
        'userSuggestedItemName', 'userSuggestedCategory', 'userSuggestedMaterial',
        'userNotes', 'feedbackTimestamp', 'reviewStatus',
        'adminReviewerId', 'adminReviewTimestamp', 'adminNotes',
        'appVersion', 'deviceInfo'
      ])
      && data.userId is string
      && data.userId.size() > 0
      && data.originalClassificationId is string
      && data.originalClassificationId.size() > 0
      && data.originalAIItemName is string
      && data.originalAICategory is string
      && data.userSuggestedCategory is string
      && data.userSuggestedCategory.size() > 0
      && data.feedbackTimestamp is timestamp
      && data.reviewStatus is string
      && data.appVersion is string;
    }
    
    function validateClassificationFeedbackUpdate(data) {
      // Updates must preserve core identity fields and userId ownership
      return data.keys().hasAll(['userId', 'originalClassificationId'])
        && data.userId is string
        && data.originalClassificationId is string
        && data.keys().hasOnly([
          'userId', 'originalClassificationId', 'originalAIItemName',
          'originalAICategory', 'originalAIMaterial', 'originalAIConfidence',
          'userSuggestedItemName', 'userSuggestedCategory', 'userSuggestedMaterial',
          'userNotes', 'feedbackTimestamp', 'reviewStatus',
          'adminReviewerId', 'adminReviewTimestamp', 'adminNotes',
          'appVersion', 'deviceInfo'
        ]);
    }

  }
}
